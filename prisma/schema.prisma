generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaperSource {
  ARXIV
  PDF_URL
}

enum PaperStatus {
  INGESTING
  READY
  FAILED
}

enum SummaryStatus {
  IDLE
  PROCESSING
  READY
  FAILED
}

enum EmbeddingKind {
  PAPER
  SECTION
  SUMMARY
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  papers        Paper[]
  chatThreads   ChatThread[]
  embeddings    Embedding[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Paper {
  id                 String          @id @default(cuid())
  userId             String
  sourceType         PaperSource
  sourceUrl          String
  title              String
  authors            String[]
  abstract           String?
  rawText            String?
  pdfUrl             String?
  publishedAt        DateTime?
  venue              String?
  status             PaperStatus     @default(INGESTING)
  summaryStatus      SummaryStatus   @default(IDLE)
  ingestionError     String?
  summaryError       String?
  summaryVersion     Int             @default(0)
  summaryData        Json?
  embedding2d        Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections           PaperSection[]
  figures            PaperFigure[]
  references         PaperReference[]
  summaries          PaperSummary[]
  chatThreads        ChatThread[]
  embeddings         Embedding[]

  @@index([userId, createdAt(sort: Desc)])
}

model PaperSection {
  id         String   @id @default(cuid())
  paperId     String
  heading     String?
  content     String
  orderIndex  Int
  pageStart   Int?
  pageEnd     Int?
  createdAt   DateTime @default(now())
  paper       Paper     @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId, orderIndex])
}

model PaperFigure {
  id          String   @id @default(cuid())
  paperId      String
  label       String
  caption     String?
  imageUrl    String?
  page        Int?
  createdAt   DateTime @default(now())
  paper       Paper     @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model PaperReference {
  id          String   @id @default(cuid())
  paperId      String
  citeKey     String?
  title       String?
  authors     String[]
  year        Int?
  rawText     String
  createdAt   DateTime @default(now())
  paper       Paper     @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model PaperSummary {
  id          String    @id @default(cuid())
  paperId      String
  version     Int
  model       String
  promptHash  String
  content     Json
  createdAt   DateTime  @default(now())
  paper       Paper      @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId, createdAt(sort: Desc)])
}

model ChatThread {
  id          String        @id @default(cuid())
  userId      String
  paperId     String
  title       String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paper       Paper         @relation(fields: [paperId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@index([userId, updatedAt(sort: Desc)])
}

model ChatMessage {
  id          String   @id @default(cuid())
  threadId     String
  role        String
  content     String
  citations   Json?
  createdAt   DateTime @default(now())
  thread      ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Embedding {
  id          String        @id @default(cuid())
  userId      String
  paperId     String?
  kind        EmbeddingKind
  sourceId    String
  vector      Json
  projection2d Json?
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paper       Paper?        @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
}
